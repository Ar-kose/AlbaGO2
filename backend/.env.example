# ============================================
# AlbaGo Backend Environment Configuration
# ============================================

# --- DATABASE_URL: Runtime connection (can use pooler) ---
# Used by Prisma for normal queries at runtime.
# Supabase Session Pooler (recommended for runtime):
#   DATABASE_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public"
DATABASE_URL="postgresql://alba:alba@localhost:5432/alba?schema=public"

# --- DIRECT_URL: Migration/DDL connection (must be direct, NOT transaction pooler) ---
# Prisma migrations require a direct connection. Do NOT use port 6543 (Transaction Pooler).
# Supabase Direct Connection:
#   DIRECT_URL="postgresql://postgres:[PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres"
#
# If DIRECT_URL is not set, Prisma will use DATABASE_URL for migrations too.
# In that case, DATABASE_URL must point to a direct/session connection, not transaction pooler.
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres"

# --- Persistence mode ---
PERSISTENCE_MODE="prisma"

# --- In-memory fallback ---
ALLOW_IN_MEMORY_FALLBACK="false"

# --- Auto seed demo games (development only) ---
# Set to "true" only in local dev to auto-populate an empty database with seed games.
# Beta/production must keep this "false" — games should come from Admin publish flow.
AUTO_SEED_DEMO_GAMES="false"

# --- Internal Admin API Security (beta/production) ---
# Set both to protect internal write endpoints (publish, create, update).
# Leave unset or REQUIRE_INTERNAL_ADMIN_TOKEN=false for local development.
# INTERNAL_ADMIN_TOKEN="<set-locally>"
# REQUIRE_INTERNAL_ADMIN_TOKEN="true"

# --- Server ---
PORT=3000
NODE_ENV=development
